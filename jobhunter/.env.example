# Copy this to .env and fill in your keys
# Usage: source .env before running main.py

# Required for LLM reranking + cover letter generation
# Get free key at: https://console.anthropic.com
export ANTHROPIC_API_KEY=sk-ant-...

# Optional: Telegram real-time alerts for high-value leads
# 1. Message @BotFather on Telegram → /newbot → copy token
# 2. Message @userinfobot to get your chat_id
export TELEGRAM_BOT_TOKEN=
export TELEGRAM_CHAT_ID=
